# Copy this to .env and fill in your keys. .env is gitignored.

# SEC EDGAR requires a User-Agent header identifying you. Format: "Name email@example.com"
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="Your Name your.email@example.com"

# WRDS — username only. Password lives in ~/.pgpass (set up via:
# python -c "import wrds; wrds.Connection()"). See docs/wrds-setup.md.
WRDS_USERNAME=""

# Nasdaq Data Link — Sharadar SF1 fundamentals (PIT, 1998+, GFC-covering).
# Get the key from data.nasdaq.com after subscribing to SHARADAR/SF1.
NASDAQ_DATA_LINK_API_KEY=""
